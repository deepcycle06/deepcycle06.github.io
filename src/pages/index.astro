---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import WedgeContrast from '../components/WedgeContrast.astro';
import PainPointBlock from '../components/PainPointBlock.astro';
import HowItWorks from '../components/HowItWorks.astro';
import FeatureList from '../components/FeatureList.astro';
import IndustriesSection from '../components/IndustriesSection.astro';
import PricingCards from '../components/PricingCards.astro';
import FAQSection from '../components/FAQSection.astro';
import DemoPlanner from '../components/DemoPlanner.tsx';
import LeadForm from '../components/LeadForm.tsx';
import { SITE } from '../config/site';

const painItems = [
  {
    title: 'Understaffed at the peak',
    body: 'You limp into your busiest weeks at 70% crew. Missed covers, burned-out staff, reviews you can\'t undo — and the revenue you lose in peak weeks you never get back.',
  },
  {
    title: 'Overstaffed in the off-season',
    body: 'You keep people on "just in case" through the quiet months and bleed payroll every week the demand simply isn\'t there.',
  },
  {
    title: 'Hiring too late',
    body: 'You post the jobs the week you\'re already drowning — when every other seasonal employer is chasing the same people, and the good ones are long gone.',
  },
];

const pillars = [
  {
    title: 'Forecast the season, not the week',
    body: 'Pick your business type and we build a 12-month demand curve — peak timing, intensity and the wobble around it — then turn it into how many people you\'ll need each month.',
  },
  {
    title: 'Hire before the rush, not during it',
    body: 'Tell us your hiring lead time and we work backward: "Start hiring by early March — add 3 for your May–July peak." No more posting jobs the week you\'re already underwater, when the good people are gone.',
  },
  {
    title: 'See the gaps and the waste',
    body: 'We line the crew you\'ll need against the crew you have and flag both: the months you\'ll be short, and the months you\'re carrying payroll you don\'t need.',
  },
  {
    title: 'A labor-cost plan you can defend',
    body: 'A month-by-month cost projection in your currency, with what you save versus your current plan — numbers and dates you can hand to a partner or a bank.',
  },
];

const homepageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: SITE.url,
    inLanguage: 'en',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: SITE.name,
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Web',
    description: SITE.description,
    offers: [
      { '@type': 'Offer', name: 'Season Plan', price: '59', priceCurrency: 'USD', category: 'OneTime' },
      { '@type': 'Offer', name: 'Pro', price: '39', priceCurrency: 'USD', category: 'Subscription' },
      { '@type': 'Offer', name: 'Multi-Site', price: '89', priceCurrency: 'USD', category: 'Subscription' },
    ],
  },
];
---

<BaseLayout
  title="Aheadcount — seasonal staffing forecast & hire-by dates"
  description="Aheadcount forecasts your seasonal demand 12 months out, sizes the crew you need each month, and tells you exactly when to start hiring — the planning layer above your scheduling app."
  schema={homepageSchema}
>
  <Hero />
  <WedgeContrast />
  <PainPointBlock
    eyebrow="The core problem"
    title="Planning seasonal staff on gut feel costs you twice — once short, once spare."
    items={painItems}
  />
  <HowItWorks />

  <section class="section bg-white" id="demo">
    <div class="container-x">
      <span class="eyebrow">Live demo · runs in your browser</span>
      <h2 class="h2 mt-2 max-w-3xl">Try it with your own numbers.</h2>
      <p class="mt-4 max-w-2xl text-primary/70">
        This is the real engine — not a screenshot. Change any input and the forecast, staffing gap, hiring dates and
        cost update instantly. It starts on the Bayside Beach Cafe example from above.
      </p>
      <div class="mt-10">
        <DemoPlanner client:visible />
      </div>
      <p class="mt-6 text-sm text-primary/55">
        Saving scenarios, PDF export and importing your own history are what the paid tiers add —
        <a href="#lead" class="text-accent underline">join the beta</a> to help decide what we build first.
      </p>
    </div>
  </section>

  <FeatureList
    eyebrow="What you get"
    title="Four things your spreadsheet and your scheduler don't give you."
    items={pillars}
  />
  <IndustriesSection />
  <PricingCards segment="homepage" />
  <FAQSection />

  <section class="section bg-white" id="lead">
    <div class="container-x grid gap-10 lg:grid-cols-2">
      <div class="max-w-xl">
        <span class="eyebrow">Early access</span>
        <h2 class="h2 mt-2">Join the beta.</h2>
        <p class="mt-4 text-primary/70">
          The forecasting engine is live today. The beta adds saving, export, scenarios and your-own-data import.
          Signing up costs nothing and commits you to nothing — and beta sign-ups get a founding-customer discount at launch.
        </p>
        <ul class="mt-6 space-y-2 text-sm text-primary/70">
          <li>No spam, no selling your data.</li>
          <li>Updates only when there's something real to share.</li>
          <li>Unsubscribe in one click, always.</li>
        </ul>
      </div>
      <div class="card">
        <LeadForm client:load segment="homepage" />
      </div>
    </div>
  </section>
</BaseLayout>
