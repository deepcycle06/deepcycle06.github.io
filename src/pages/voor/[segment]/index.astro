---
import SegmentLayout from '../../../layouts/SegmentLayout.astro';
import SegmentHero from '../../../components/SegmentHero.astro';
import PainPointBlock from '../../../components/PainPointBlock.astro';
import MockupGallery from '../../../components/MockupGallery.astro';
import PricingCards from '../../../components/PricingCards.astro';
import FAQSection from '../../../components/FAQSection.astro';
import LeadForm from '../../../components/LeadForm.tsx';
import { SEGMENTS, getSegment, type SegmentSlug } from '../../../data/segments';

export function getStaticPaths() {
  return SEGMENTS.map((s) => ({
    params: { segment: s.slug },
    props: { slug: s.slug },
  }));
}

const { slug } = Astro.props as { slug: SegmentSlug };
const segment = getSegment(slug);
---

<SegmentLayout segment={segment}>
  <SegmentHero segment={segment} />

  <PainPointBlock
    title={`Pijnpunten in ${segment.shortLabel}`}
    eyebrow="Waarom dit specifiek voor jouw sector"
    items={segment.painPoints}
  />

  <section class="section bg-white" id="how">
    <div class="container-x">
      <span class="eyebrow">Hoe het werkt voor {segment.shortLabel}</span>
      <h2 class="h2 mt-2 max-w-3xl">In drie stappen van "we zien wel" naar "ik weet wat ik doe".</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {segment.steps.map((s) => (
          <article class="card">
            <h3 class="text-lg font-semibold">{s.title}</h3>
            <p class="mt-2 text-sm text-primary/70">{s.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-primary/5">
    <div class="container-x max-w-4xl">
      <div class="card">
        <span class="badge bg-warning/10 text-warning">{segment.miniCase.label}</span>
        <h3 class="mt-3 text-2xl font-semibold">{segment.miniCase.title}</h3>
        <p class="mt-3 text-primary/70">{segment.miniCase.body}</p>
        <p class="mt-4 text-xs text-primary/50">
          Voorbeeld dient ter illustratie. Geen echte klantdata — we zijn in beta.
        </p>
      </div>
    </div>
  </section>

  <MockupGallery />

  <PricingCards segment={segment.slug} />

  <FAQSection />

  <section class="section bg-white" id="lead">
    <div class="container-x grid gap-10 lg:grid-cols-2">
      <div class="max-w-xl">
        <span class="eyebrow">Voor {segment.shortLabel}</span>
        <h2 class="h2 mt-2">Schrijf je in voor vroege toegang.</h2>
        <p class="mt-4 text-primary/70">
          We prioriseren de sector-varianten op basis van signup-volume. Door je hier in te schrijven
          laat je ons weten dat {segment.shortLabel.toLowerCase()} een harde validator moet krijgen.
        </p>
        <p class="mt-4 text-primary/70">
          Niet jouw sector? <a class="underline text-accent" href="/">Bekijk andere varianten op de homepage.</a>
        </p>
      </div>
      <div class="card">
        <LeadForm client:load segment={segment.slug} heading={`Vroege toegang voor ${segment.shortLabel.toLowerCase()}`} />
      </div>
    </div>
  </section>
</SegmentLayout>
