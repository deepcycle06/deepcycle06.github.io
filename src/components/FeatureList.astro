---
export interface Feature {
  title: string;
  body: string;
  icon?: string;
}
export interface Props {
  title?: string;
  eyebrow?: string;
  items: Feature[];
}

const {
  title = 'What you get',
  eyebrow = 'The promise',
  items,
} = Astro.props;
---
<section class="section bg-white" id="features">
  <div class="container-x">
    <span class="eyebrow">{eyebrow}</span>
    <h2 class="h2 mt-2 max-w-3xl">{title}</h2>
    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {items.map((f) => (
        <article class="flex gap-4 rounded-2xl border border-primary/10 bg-white p-6">
          <div class="flex h-10 w-10 flex-none items-center justify-center rounded-lg bg-accent/10 text-accent">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <h3 class="text-base font-semibold">{f.title}</h3>
            <p class="mt-1 text-sm text-primary/70">{f.body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
