---
import { PRICING, ENTERPRISE_NOTE } from '../data/pricing';
import IntentTracker from './IntentTracker.tsx';

export interface Props {
  segment?: string;
}
const { segment = 'homepage' } = Astro.props;
---
<section class="section bg-white" id="pricing">
  <div class="container-x">
    <div class="flex flex-col items-start gap-2">
      <span class="eyebrow">Pricing beta</span>
      <h2 class="h2">Transparante prijzen. Beta-korting tot launch.</h2>
      <p class="max-w-2xl text-primary/70">
        Reserveer nu, betaal pas bij live. Beta-klanten krijgen 50% early-bird korting op het eerste jaar (Pro/Team) of eenmalig (Starter).
      </p>
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {PRICING.map((tier) => (
        <div class={`card relative flex h-full flex-col ${tier.highlight ? 'border-accent shadow-lg ring-1 ring-accent/30' : ''}`}>
          <span class="badge-beta self-start">Beta-korting 50% early bird</span>
          {tier.highlight && (
            <span class="absolute right-4 top-4 rounded-full bg-accent px-3 py-1 text-xs font-semibold text-white">Populair</span>
          )}
          <h3 class="mt-3 text-lg font-semibold">{tier.name}</h3>
          <div class="mt-2 flex items-baseline gap-2">
            <span class="text-4xl font-bold">{tier.price}</span>
            <span class="text-sm text-primary/60">{tier.priceSub}</span>
          </div>
          <p class="mt-3 text-sm text-primary/70">{tier.tagline}</p>
          <ul class="mt-6 space-y-2 text-sm">
            {tier.features.map((f) => (
              <li class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mt-0.5 h-4 w-4 flex-none text-success"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <div class="mt-8">
            <IntentTracker
              client:load
              intent={tier.intent}
              segment={segment}
              label={tier.cta}
              variant={tier.highlight ? 'primary' : 'secondary'}
            />
          </div>
        </div>
      ))}
    </div>
    <p class="mt-8 text-center text-sm text-primary/60">{ENTERPRISE_NOTE}</p>
  </div>
</section>
