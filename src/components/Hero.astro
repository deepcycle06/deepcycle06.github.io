---
import TrustBadges from './TrustBadges.astro';
import ForecastChart from '../assets/mockups/forecast-chart.astro';
---
<section class="relative overflow-hidden bg-gradient-to-b from-white to-primary/5">
  <div class="container-x grid items-center gap-12 py-20 sm:py-24 lg:grid-cols-2 lg:py-28">
    <div>
      <span class="eyebrow">Beta — vroege toegang</span>
      <h1 class="h1 mt-3 text-primary">
        Stop met personeel plannen op gevoel en "vorig jaar ook".
      </h1>
      <p class="mt-6 text-lg text-primary/70">
        Data-gedreven FTE-forecast voor seizoensgebonden Belgische bedrijven.
        Weer + evenementen + jouw historie + sector-benchmarks gecombineerd in één planning-tool.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="#lead" class="btn-primary">Schrijf me in voor vroege toegang</a>
        <a href="#how" class="btn-secondary">Hoe het werkt</a>
      </div>
      <div class="mt-8">
        <TrustBadges />
      </div>
    </div>
    <div class="relative">
      <div class="rounded-2xl border border-primary/10 bg-white p-4 shadow-xl">
        <ForecastChart />
      </div>
      <p class="mt-2 text-right text-xs text-primary/50">Illustratief dashboard — beta</p>
    </div>
  </div>
</section>
