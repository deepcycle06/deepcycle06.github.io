---
import { SITE } from '../config/site';
const year = new Date().getFullYear();
---

<footer class="border-t border-primary/10 bg-primary text-white">
  <div class="container-x grid gap-10 py-12 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <div class="flex items-center gap-2 font-bold">
        <span class="inline-block h-6 w-6 rounded-md bg-accent"></span>
        {SITE.name}
      </div>
      <p class="mt-3 text-sm text-white/70">
        The staffing-forecast layer above your scheduler. Prototype — early access by sign-up.
      </p>
    </div>
    <div>
      <h4 class="text-sm font-semibold uppercase tracking-wider text-white/60">Product</h4>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/#how" class="text-white/80 hover:text-white">How it works</a></li>
        <li><a href="/#demo" class="text-white/80 hover:text-white">Live demo</a></li>
        <li><a href="/#industries" class="text-white/80 hover:text-white">Industries</a></li>
        <li><a href="/#pricing" class="text-white/80 hover:text-white">Pricing</a></li>
      </ul>
    </div>
    <div>
      <h4 class="text-sm font-semibold uppercase tracking-wider text-white/60">Company</h4>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/about/" class="text-white/80 hover:text-white">About</a></li>
        <li><a href="/#faq" class="text-white/80 hover:text-white">FAQ</a></li>
        <li><a href="/#lead" class="text-white/80 hover:text-white">Join the beta</a></li>
      </ul>
    </div>
    <div>
      <h4 class="text-sm font-semibold uppercase tracking-wider text-white/60">Legal</h4>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/privacy/" class="text-white/80 hover:text-white">Privacy</a></li>
        <li><a href="/terms/" class="text-white/80 hover:text-white">Terms</a></li>
        <li><a href="/cookies/" class="text-white/80 hover:text-white">Cookies</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-white/10">
    <div class="container-x flex flex-col items-start justify-between gap-2 py-6 text-xs text-white/60 sm:flex-row">
      <p>&copy; {year} {SITE.name}.</p>
      <p>Contact: <a class="underline hover:text-white" href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a></p>
    </div>
  </div>
</footer>
