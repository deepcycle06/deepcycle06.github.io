---
// Fire plausible-events bij 50/75/100% scroll-diepte, eenmalig per pageview.
---
<script is:inline>
  (function () {
    if (typeof window === 'undefined') return;
    const fired = new Set();
    function onScroll() {
      const h = document.documentElement;
      const scrolled = (window.scrollY + window.innerHeight) / h.scrollHeight;
      [50, 75, 100].forEach(function (pct) {
        if (!fired.has(pct) && scrolled * 100 >= pct) {
          fired.add(pct);
          try {
            if (window.plausible) {
              window.plausible('scroll_depth_' + pct);
            }
          } catch (_) { /* noop */ }
        }
      });
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('load', onScroll);
  })();
</script>
