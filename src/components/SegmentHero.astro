---
import TrustBadges from './TrustBadges.astro';
import ForecastChart from '../assets/mockups/forecast-chart.astro';
import type { Segment } from '../data/segments';

export interface Props {
  segment: Segment;
}

const { segment } = Astro.props;
---
<section class="relative overflow-hidden bg-gradient-to-b from-white to-primary/5">
  <div class="container-x grid items-center gap-12 py-16 sm:py-20 lg:grid-cols-2 lg:py-24">
    <div>
      <div class="flex flex-wrap items-center gap-2">
        <span class="eyebrow">Voor {segment.shortLabel}</span>
        <span class="badge-beta">Beta</span>
      </div>
      <h1 class="h1 mt-3 text-primary">{segment.heroTitle}</h1>
      <p class="mt-6 text-lg text-primary/70">{segment.heroSubtitle}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="#lead" class="btn-primary">Reserveer vroege toegang</a>
        <a href="#how" class="btn-secondary">Hoe het werkt voor {segment.shortLabel}</a>
      </div>
      <div class="mt-8">
        <TrustBadges />
      </div>
    </div>
    <div class="relative">
      <div class="rounded-2xl border border-primary/10 bg-white p-4 shadow-xl">
        <ForecastChart />
      </div>
      <p class="mt-2 text-right text-xs text-primary/50">Illustratief dashboard — beta</p>
    </div>
  </div>
</section>
