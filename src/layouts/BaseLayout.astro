---
import '../styles/globals.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollDepthTracker from '../components/ScrollDepthTracker.astro';
import { SITE } from '../config/site';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = '/og/og-default.svg',
  schema,
  noindex = false,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE.url).toString();
const schemaList = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Host-independent security baseline. GitHub Pages ignores public/_headers, so we set
         the CSP fetch-directives here so they apply everywhere. HSTS, frame-ancestors and
         Permissions-Policy can't be set via <meta> and live in public/_headers (active once
         the site sits behind a header-respecting host like Cloudflare/Netlify). -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self' https://cloudflareinsights.com https://static.cloudflareinsights.com https://formspree.io; form-action 'self' https://formspree.io; base-uri 'self'; object-src 'none'"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, SITE.url).toString()} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={SITE.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, SITE.url).toString()} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {schemaList.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- Cloudflare Web Analytics (free, cookieless, privacy-friendly).
         Loads only when SITE.CF_BEACON_TOKEN is set — otherwise no beacon at all.
         Create a token: dash.cloudflare.com → Web Analytics → Add a site. -->
    {SITE.CF_BEACON_TOKEN && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: SITE.CF_BEACON_TOKEN })}
      />
    )}
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-2 focus:top-2 focus:z-50 focus:rounded focus:bg-accent focus:px-3 focus:py-2 focus:text-white">Skip to main content</a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <ScrollDepthTracker />
  </body>
</html>
