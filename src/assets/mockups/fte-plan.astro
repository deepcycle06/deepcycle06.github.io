---
// FTE-plan per week: 12 weken × 4 rijen (vast, flexi, student, interim).
// Waarden per rij per week (0-8 FTE) — gradient van laag naar hoog in seizoen.
const weeks = Array.from({ length: 12 }, (_, i) => `w${i + 1}`);

type Row = { label: string; color: string; values: number[] };
const rows: Row[] = [
  { label: 'Vast',    color: '#0F172A', values: [3,3,3,3,3,3,3,3,3,3,3,3] },
  { label: 'Flexi',   color: '#2563EB', values: [1,1,2,3,4,5,6,6,5,4,3,2] },
  { label: 'Student', color: '#059669', values: [0,0,1,2,3,4,5,5,4,2,1,0] },
  { label: 'Interim', color: '#D97706', values: [0,0,0,1,2,3,3,3,2,1,0,0] },
];

const W = 400;
const H = 220;
const padL = 60;
const padR = 12;
const padT = 28;
const padB = 28;
const cellW = (W - padL - padR) / weeks.length;
const rowH = (H - padT - padB) / rows.length;
const maxVal = 8;

function cellColor(base: string, v: number) {
  const ratio = Math.min(1, v / maxVal);
  // Use opacity for "gradient"
  return { fill: base, opacity: 0.15 + ratio * 0.8 };
}
---
<svg
  role="img"
  aria-label="Illustratief FTE-plan: 12 weken met 4 contracttypes (vast, flexi, student, interim) in kleur-gradient"
  viewBox={`0 0 ${W} ${H}`}
  xmlns="http://www.w3.org/2000/svg"
  class="h-auto w-full"
>
  <title>Illustratief FTE-plan per week</title>
  <desc>Matrix van 12 weken × 4 rijen. Donkerder kleur = meer FTE per type. Vaste medewerkers zijn constant, flexi en student pieken in week 7-8.</desc>
  <rect width={W} height={H} rx="8" fill="#f8fafc"/>

  <text x={padL} y={18} font-size="11" font-weight="600" fill="#0F172A">FTE-plan per week — illustratief</text>

  {weeks.map((w, i) => (
    <text x={padL + cellW * i + cellW / 2} y={padT - 6} text-anchor="middle" font-size="9" fill="#64748b">{w}</text>
  ))}

  {rows.map((row, rIdx) => (
    <g>
      <text x={padL - 8} y={padT + rowH * rIdx + rowH / 2 + 3} text-anchor="end" font-size="10" fill="#0F172A" font-weight="500">{row.label}</text>
      {row.values.map((v, i) => {
        const c = cellColor(row.color, v);
        return (
          <g>
            <rect
              x={padL + cellW * i + 1}
              y={padT + rowH * rIdx + 1}
              width={cellW - 2}
              height={rowH - 2}
              rx="3"
              fill={c.fill}
              fill-opacity={c.opacity}
            />
            <text
              x={padL + cellW * i + cellW / 2}
              y={padT + rowH * rIdx + rowH / 2 + 3}
              text-anchor="middle"
              font-size="9"
              fill={v > 3 ? '#ffffff' : '#0F172A'}
              font-weight="600"
            >{v}</text>
          </g>
        );
      })}
    </g>
  ))}
</svg>
