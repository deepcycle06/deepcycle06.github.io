  "simple-git-hooks": {
    "pre-commit": "sh -c 'files=$(git diff --cached --name-only --diff-filter=ACM); [ -z \"$files\" ] && exit 0; echo \"$files\" | xargs npx --no-install secretlint --secretlintignore .gitignore'"
